@page "/"
@using JaxaRainmap.Models
@using JaxaRainmap.Services
@using JaxaRainmap.Components.Map
@using JaxaRainmap.Components.Controls
@using JaxaRainmap.Components.Shared
@inject IGsmapService GsmapService

<PageTitle>JAXA Rain Radar \u2014 GSMaP</PageTitle>

<div class="home-layout">
    <div class="controls-panel">
        <DateTimeSelector
            SelectedDate="@_settings.SelectedDate"
            SelectedDateChanged="OnDateChanged"
            SelectedHour="@_settings.SelectedHour"
            SelectedHourChanged="OnHourChanged"
            OnSelectionChanged="LoadCurrentFrame" />

        <LayerSelector
            SelectedType="@_settings.CollectionType"
            SelectedTypeChanged="OnCollectionTypeChanged" />

        <RegionSelector OnRegionSelected="OnRegionSelected" />

        <AnimationControls
            Frames="_frames"
            CurrentFrameIndex="_currentFrameIndex"
            CurrentFrameIndexChanged="OnFrameIndexChanged"
            IsPlaying="_settings.IsPlaying"
            IsPlayingChanged="OnPlayingChanged"
            PlaybackSpeed="_settings.PlaybackSpeed"
            PlaybackSpeedChanged="OnSpeedChanged" />

        <ColorLegend
            SelectedPalette="@_settings.ColorPalette"
            SelectedPaletteChanged="OnPaletteChanged" />
    </div>

    <div class="map-panel">
        <LeafletMap @ref="_mapRef"
                    MapElementId="rainmap"
                    CenterLat="@_settings.CenterLat"
                    CenterLon="@_settings.CenterLon"
                    Zoom="@_settings.Zoom"
                    OnLayerLoaded="OnLayerLoaded" />

        <LoadingOverlay IsVisible="@_isLoading" Message="@_loadingMessage" />
    </div>
</div>

@code {
    private LeafletMap? _mapRef;
    private MapSettings _settings = new();
    private List<PrecipitationFrame> _frames = new();
    private int _currentFrameIndex = 0;
    private bool _isLoading = false;
    private string _loadingMessage = "Loading precipitation data...";
    private System.Timers.Timer? _animationTimer;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadFramesForDateRange();
        }
    }

    private async Task LoadFramesForDateRange()
    {
        _isLoading = true;
        _loadingMessage = "Fetching precipitation data...";
        StateHasChanged();

        try
        {
            var startDate = _settings.SelectedDate.Date;
            var endDate = _settings.CollectionType == "daily"
                ? startDate.AddDays(7)
                : startDate.AddMonths(6);

            _frames = await GsmapService.GetFramesAsync(_settings.CollectionType, startDate, endDate);

            if (_frames.Count > 0)
            {
                _currentFrameIndex = 0;
                await LoadFrameOnMap(_frames[0]);
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error loading frames: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadFrameOnMap(PrecipitationFrame frame)
    {
        if (_mapRef is null) return;

        _isLoading = true;
        _loadingMessage = $"Loading {frame.DisplayLabel}...";
        StateHasChanged();

        await _mapRef.LoadPrecipitationAsync(frame.CogUrl, _settings.ColorPalette, additionalUrls: frame.AdditionalCogUrls);

        _isLoading = false;
        StateHasChanged();
    }

    private async Task LoadCurrentFrame()
    {
        await LoadFramesForDateRange();
    }

    private async Task OnDateChanged(DateTime date)
    {
        _settings.SelectedDate = date;
        await LoadFramesForDateRange();
    }

    private Task OnHourChanged(int hour)
    {
        _settings.SelectedHour = hour;
        return Task.CompletedTask;
    }

    private async Task OnCollectionTypeChanged(string type)
    {
        _settings.CollectionType = type;
        await LoadFramesForDateRange();
    }

    private async Task OnRegionSelected(RegionPreset region)
    {
        if (_mapRef is not null)
        {
            await _mapRef.FitBoundsAsync(region.South, region.West, region.North, region.East);
        }
    }

    private async Task OnPaletteChanged(string palette)
    {
        _settings.ColorPalette = palette;
        if (_frames.Count > _currentFrameIndex)
        {
            await LoadFrameOnMap(_frames[_currentFrameIndex]);
        }
    }

    private async Task OnFrameIndexChanged(int index)
    {
        _currentFrameIndex = index;
        if (_frames.Count > index)
        {
            await LoadFrameOnMap(_frames[index]);
        }
    }

    private void OnPlayingChanged(bool isPlaying)
    {
        _settings.IsPlaying = isPlaying;

        if (isPlaying)
        {
            StartAnimation();
        }
        else
        {
            StopAnimation();
        }
    }

    private void OnSpeedChanged(double speed)
    {
        _settings.PlaybackSpeed = speed;
        if (_settings.IsPlaying)
        {
            StopAnimation();
            StartAnimation();
        }
    }

    private void StartAnimation()
    {
        StopAnimation();

        var interval = 1000.0 / _settings.PlaybackSpeed;
        _animationTimer = new System.Timers.Timer(interval);
        _animationTimer.Elapsed += async (_, _) =>
        {
            if (_frames.Count == 0) return;

            _currentFrameIndex = (_currentFrameIndex + 1) % _frames.Count;

            await InvokeAsync(async () =>
            {
                if (_mapRef is not null && _frames.Count > _currentFrameIndex)
                {
                    await _mapRef.SwapFrameAsync(
                        _frames[_currentFrameIndex].CogUrl,
                        _settings.ColorPalette,
                        additionalUrls: _frames[_currentFrameIndex].AdditionalCogUrls);
                }
                StateHasChanged();
            });
        };
        _animationTimer.Start();
    }

    private void StopAnimation()
    {
        _animationTimer?.Stop();
        _animationTimer?.Dispose();
        _animationTimer = null;
    }

    private void OnLayerLoaded(bool success)
    {
        if (!success)
        {
            Console.Error.WriteLine("Failed to load precipitation layer");
        }
    }

    public void Dispose()
    {
        StopAnimation();
    }
}
