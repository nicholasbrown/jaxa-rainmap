@page "/"
@using JaxaRainmap.Models
@using JaxaRainmap.Services
@using JaxaRainmap.Components.Map
@using JaxaRainmap.Components.Controls
@using JaxaRainmap.Components.Shared
@inject IGsmapService GsmapService
@inject ILogger<Home> Logger

<PageTitle>JAXA Rain Radar — GSMaP</PageTitle>

<div class="home-layout">
    <div class="controls-panel">
        <DateTimeSelector
            SelectedDate="@_settings.SelectedDate"
            SelectedDateChanged="OnDateChanged"
            SelectedHour="@_settings.SelectedHour"
            SelectedHourChanged="OnHourChanged"
            OnSelectionChanged="LoadCurrentFrame" />

        <LayerSelector
            SelectedType="@_settings.CollectionType"
            SelectedTypeChanged="OnCollectionTypeChanged" />

        <RegionSelector OnRegionSelected="OnRegionSelected" />

        <AnimationControls
            Frames="_frames"
            CurrentFrameIndex="_currentFrameIndex"
            CurrentFrameIndexChanged="OnFrameIndexChanged"
            IsPlaying="_settings.IsPlaying"
            IsPlayingChanged="OnPlayingChanged"
            PlaybackSpeed="_settings.PlaybackSpeed"
            PlaybackSpeedChanged="OnSpeedChanged"
            AnimationDays="_animationDays"
            AnimationDaysChanged="OnAnimationDaysChanged"
            IsBuffering="_isBuffering"
            BufferLoaded="_bufferLoaded"
            BufferTotal="_bufferTotal" />

        <ColorLegend
            SelectedPalette="@_settings.ColorPalette"
            SelectedPaletteChanged="OnPaletteChanged" />
    </div>

    <div class="map-panel">
        <LeafletMap @ref="_mapRef"
                    MapElementId="rainmap"
                    CenterLat="@_settings.CenterLat"
                    CenterLon="@_settings.CenterLon"
                    Zoom="@_settings.Zoom"
                    OnLayerLoaded="OnLayerLoaded" />

        <LoadingOverlay IsVisible="@_isLoading" Message="@_loadingMessage" />
    </div>
</div>

@code {
    private LeafletMap? _mapRef;
    private MapSettings _settings = new();
    private List<PrecipitationFrame> _frames = new();
    private int _currentFrameIndex = 0;
    private bool _isLoading = false;
    private string _loadingMessage = "Loading precipitation data...";
    private int _animationDays = 30;
    private bool _isBuffering = false;
    private int _bufferLoaded = 0;
    private int _bufferTotal = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Subscribe to JS animation callbacks
            JaxaRainmap.Services.Logging.JsLogBridge.OnBufferProgress += OnBufferProgress;
            JaxaRainmap.Services.Logging.JsLogBridge.OnAnimFrameChanged += OnAnimFrameChanged;
            await LoadFramesForDateRange();
        }
    }

    private async Task LoadFramesForDateRange()
    {
        _isLoading = true;
        _loadingMessage = "Fetching precipitation data...";
        StateHasChanged();

        try
        {
            var endDate = _settings.SelectedDate.Date;
            var startDate = _settings.CollectionType == "daily"
                ? endDate.AddDays(-_animationDays)
                : endDate.AddMonths(-6);

            Logger.LogDebug("Loading frames: {Type} from {Start:yyyy-MM-dd} to {End:yyyy-MM-dd}",
                _settings.CollectionType, startDate, endDate);

            _frames = await GsmapService.GetFramesAsync(_settings.CollectionType, startDate, endDate);

            Logger.LogInformation("Loaded {FrameCount} frames for {Type}", _frames.Count, _settings.CollectionType);

            if (_frames.Count > 0)
            {
                _currentFrameIndex = 0;
                await LoadFrameOnMap(_frames[0]);
            }
            else
            {
                Logger.LogWarning("No frames available for date range {Start:yyyy-MM-dd} to {End:yyyy-MM-dd}",
                    startDate, endDate);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading frames");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadFrameOnMap(PrecipitationFrame frame)
    {
        if (_mapRef is null) return;

        _isLoading = true;
        _loadingMessage = $"Loading {frame.DisplayLabel}...";
        StateHasChanged();

        Logger.LogDebug("Loading COG frame {FrameId}: {CogUrl} (+{AdditionalCount} tiles)",
            frame.Id, frame.CogUrl, frame.AdditionalCogUrls.Count);

        await _mapRef.LoadPrecipitationAsync(frame.CogUrl, _settings.ColorPalette, additionalUrls: frame.AdditionalCogUrls);

        Logger.LogDebug("Frame {FrameId} loaded on map", frame.Id);
        _isLoading = false;
        StateHasChanged();
    }

    private async Task LoadCurrentFrame()
    {
        await LoadFramesForDateRange();
    }

    private async Task OnDateChanged(DateTime date)
    {
        _settings.SelectedDate = date;
        await LoadFramesForDateRange();
    }

    private Task OnHourChanged(int hour)
    {
        _settings.SelectedHour = hour;
        return Task.CompletedTask;
    }

    private async Task OnCollectionTypeChanged(string type)
    {
        _settings.CollectionType = type;
        await LoadFramesForDateRange();
    }

    private async Task OnRegionSelected(RegionPreset region)
    {
        if (_mapRef is not null)
        {
            await _mapRef.FitBoundsAsync(region.South, region.West, region.North, region.East);
        }
    }

    private async Task OnPaletteChanged(string palette)
    {
        _settings.ColorPalette = palette;
        if (_frames.Count > _currentFrameIndex)
        {
            await LoadFrameOnMap(_frames[_currentFrameIndex]);
        }
    }

    private async Task OnFrameIndexChanged(int index)
    {
        _currentFrameIndex = index;
        if (_frames.Count > index)
        {
            await LoadFrameOnMap(_frames[index]);
        }
    }

    private async void OnPlayingChanged(bool isPlaying)
    {
        _settings.IsPlaying = isPlaying;

        if (isPlaying)
        {
            await StartBufferedAnimation();
        }
        else
        {
            await StopAnimation();
        }
    }

    private async Task StartBufferedAnimation()
    {
        if (_mapRef is null || _frames.Count == 0) return;

        Logger.LogDebug("Starting buffered animation: {FrameCount} frames at {Speed}x",
            _frames.Count, _settings.PlaybackSpeed);

        // Phase 1: Prebuffer all frames
        _isBuffering = true;
        _bufferLoaded = 0;
        _bufferTotal = _frames.Count * 2; // 2 hemisphere tiles per frame
        StateHasChanged();

        var frameUrlSets = _frames
            .Select(f => new[] { f.CogUrl }.Concat(f.AdditionalCogUrls).ToArray())
            .ToArray();

        await _mapRef.PrebufferFramesAsync(frameUrlSets, _settings.ColorPalette);

        _isBuffering = false;
        StateHasChanged();

        Logger.LogInformation("Prebuffer complete, starting JS-driven playback");

        // Phase 2: Start JS-driven animation (all from cache, no network)
        await _mapRef.StartJsAnimationAsync(frameUrlSets, _settings.PlaybackSpeed, _settings.ColorPalette);
    }

    private async Task StopAnimation()
    {
        if (_mapRef is not null)
        {
            await _mapRef.StopJsAnimationAsync();
        }
        _isBuffering = false;
        Logger.LogDebug("Animation stopped");
        StateHasChanged();
    }

    private async void OnSpeedChanged(double speed)
    {
        _settings.PlaybackSpeed = speed;
        if (_settings.IsPlaying && _mapRef is not null)
        {
            await _mapRef.SetAnimationSpeedAsync(speed);
        }
    }

    private async Task OnAnimationDaysChanged(int days)
    {
        _animationDays = days;
        Logger.LogDebug("Animation range changed to {Days} days", days);
        await LoadFramesForDateRange();
    }

    private void OnBufferProgress(int loaded, int total)
    {
        InvokeAsync(() =>
        {
            _bufferLoaded = loaded;
            _bufferTotal = total;
            StateHasChanged();
        });
    }

    private void OnAnimFrameChanged(int frameIndex)
    {
        InvokeAsync(() =>
        {
            _currentFrameIndex = frameIndex;
            StateHasChanged();
        });
    }

    private void OnLayerLoaded(bool success)
    {
        if (!success)
        {
            Logger.LogError("Failed to load precipitation layer on map");
        }
    }

    public void Dispose()
    {
        JaxaRainmap.Services.Logging.JsLogBridge.OnBufferProgress -= OnBufferProgress;
        JaxaRainmap.Services.Logging.JsLogBridge.OnAnimFrameChanged -= OnAnimFrameChanged;
        _ = StopAnimation();
    }
}
