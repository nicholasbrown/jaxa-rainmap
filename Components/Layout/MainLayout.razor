@inherits LayoutComponentBase

<div class="app-container @(_darkMode ? "dark" : "light")">
    <aside class="sidebar">
        <div class="sidebar-header">
            <h1 class="app-title">🌧️ JAXA Rain Radar</h1>
            <p class="app-subtitle">GSMaP Precipitation Visualiser</p>
            <button class="theme-toggle" @onclick="ToggleTheme" title="Toggle theme">
                @(_darkMode ? "☀️" : "🌙")
            </button>
        </div>

        <div class="sidebar-content">
            @Body
        </div>

        <footer class="sidebar-footer">
            <p class="attribution">
                Data: <a href="https://sharaku.eorc.jaxa.jp/GSMaP/" target="_blank">GSMaP</a>
                by <a href="https://www.eorc.jaxa.jp/" target="_blank">JAXA/EORC</a>
                · <a href="/logs">Debug Logs</a>
            </p>
        </footer>
    </aside>
</div>

@code {
    private bool _darkMode = true;

    private void ToggleTheme()
    {
        _darkMode = !_darkMode;
    }
}
